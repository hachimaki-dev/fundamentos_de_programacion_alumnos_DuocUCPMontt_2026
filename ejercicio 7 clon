import random 

numero = random.randint(1,50)
ajustado = (numero // 4) * 4  

print("Adivina el multiplo de 4")

for intento in range(1,4):
    respuesta = int(input(f"Intento {intento}:"))

    if respuesta == ajustado:
        print("¡Correcto!")
        break
    else:
        print("Incorrecto")

else:
    print("Perdiste. el numero era:", ajustado)
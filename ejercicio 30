response_codes = [200, 404, 500, 200, 500]
reintentos = 1
for code in response_codes:
    if code == 200:
        print("Ok")
    elif code == 404:
        print("No encontrado")
    elif code == 500:
        reintentos -= 1
        if reintentos < 0:
            print("Servidor caido")
            break
        else:
            print("Reintentando")
